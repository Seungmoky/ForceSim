<Window x:Class="ForceSim.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ForceSim.App"
        mc:Ignorable="d"
        Title="MainWindow" Width="900" Height="600">
    <Window.Resources>
        <local:MinMaxHeatBrushConverter x:Key="MinMaxHeatBrush"/>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- controls -->
            <RowDefinition Height="*"/>
            <!-- table -->
            <RowDefinition Height="Auto"/>
            <!-- log -->
        </Grid.RowDefinitions>

        <!-- Top controls -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <ComboBox x:Name="ComboLogFiles" Width="320" Margin="0,0,8,0"
                  ItemsSource="{Binding LogFiles}"
                  SelectedItem="{Binding SelectedLogFile, Mode=TwoWay}">
                <!-- 드롭다운에 전체 경로 말고 파일명만 보이게 -->
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding FileName}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- Refresh: 아이콘 버튼(정사각형) -->
            <Button x:Name="BtnRefresh" Width="34" Height="34" Margin="0,0,8,0"
                Click="BtnRefresh_Click"
                ToolTip="Refresh">
                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16"
                       VerticalAlignment="Center" HorizontalAlignment="Center"
                       Text=""/>
            </Button>

            <Button x:Name="BtnStart" Content="Start" Width="90" Height="34" Margin="0,0,8,0" Click="BtnStart_Click"/>
            <Button x:Name="BtnStop" Content="Stop" Width="90" Height="34" Margin="0,0,8,0" Click="BtnStop_Click" IsEnabled="False"/>
            <Button x:Name="BtnReset" Content="Reset" Width="90" Height="34" Click="BtnReset_Click"/>
            <TextBlock Text="{Binding ProgressText}"
               Margin="12,0,0,0"
               VerticalAlignment="Center"
               FontFamily="Consolas"
               FontSize="12"/>
        </StackPanel>

        <!-- Table (top) -->
        <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" Padding="6">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="CellsView" ItemsSource="{Binding Cells}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <!-- 아직은 16x12 고정 (다음 단계에서 _settings.Cols/Rows로 자동화) -->
                            <UniformGrid Columns="16"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderThickness="0.5">
                                <Border.Background>
                                    <MultiBinding Converter="{StaticResource MinMaxHeatBrush}">
                                        <Binding Path="MaxSimP"/>
                                        <Binding Path="HeatMin" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding Path="HeatMax" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                    </MultiBinding>
                                </Border.Background> 
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="Gray"/>
                                        <Setter Property="BorderThickness" Value="0.5"/>

                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsHot}" Value="True">
                                                <Setter Property="BorderBrush" Value="OrangeRed"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <TextBlock Text="{Binding Label}" FontFamily="Consolas">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <!-- 기본: (col,row) -->
                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                            <Setter Property="VerticalAlignment" Value="Top"/>
                                            <Setter Property="Margin" Value="2"/>
                                            <Setter Property="FontSize" Value="10"/>
                                            <Setter Property="FontWeight" Value="Normal"/>

                                            <Style.Triggers>
                                                <!-- 값 있음: MaxSimP -->
                                                <DataTrigger Binding="{Binding HasSim}" Value="True">
                                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="Margin" Value="0"/>
                                                    <Setter Property="FontSize" Value="14"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Log (bottom, last 5 lines) -->
        <GroupBox Grid.Row="2" Height="120" Header="Real-time Log (last 5 lines)" Margin="0,8,0,0">
            <ListBox ItemsSource="{Binding LogLines}" FontFamily="Consolas" />
        </GroupBox>
    </Grid>
</Window>
